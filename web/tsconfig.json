{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "declaration": true,
        "sourceMap": true,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@axrone/scene-runtime": ["packages/scene-runtime/src"],
            "@axrone/scene-runtime/*": ["packages/scene-runtime/src/*"],
            "@axrone/ecs-events/*": ["packages/ecs-events/src/*"],
            "@axrone/ecs-query/*": ["packages/ecs-query/src/*"],
            "@axrone/ecs-storage/*": ["packages/ecs-storage/src/*"],
            "@axrone/*": ["packages/*/src"]
        },
        "types": ["vitest/globals"],
        "composite": true,
        "declarationMap": true
    },
    "exclude": ["node_modules", "dist", "build", "coverage"]
}
