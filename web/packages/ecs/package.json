{
    "name": "@axrone/ecs",
    "version": "0.1.0",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.mjs",
            "require": "./dist/core.js"
        },
        "./world": {
            "types": "./dist/world.d.ts",
            "import": "./dist/world.mjs",
            "require": "./dist/world.js"
        },
        "./actor": {
            "types": "./dist/actor.d.ts",
            "import": "./dist/actor.mjs",
            "require": "./dist/actor.js"
        },
        "./component": {
            "types": "./dist/component.d.ts",
            "import": "./dist/component.mjs",
            "require": "./dist/component.js"
        },
        "./decorators": {
            "types": "./dist/decorators.d.ts",
            "import": "./dist/decorators.mjs",
            "require": "./dist/decorators.js"
        },
        "./components": {
            "types": "./dist/components.d.ts",
            "import": "./dist/components.mjs",
            "require": "./dist/components.js"
        },
        "./systems": {
            "types": "./dist/systems.d.ts",
            "import": "./dist/systems.mjs",
            "require": "./dist/systems.js"
        },
        "./observers": {
            "types": "./dist/observers.d.ts",
            "import": "./dist/observers.mjs",
            "require": "./dist/observers.js"
        },
        "./memory": {
            "types": "./dist/memory.d.ts",
            "import": "./dist/memory.mjs",
            "require": "./dist/memory.js"
        },
        "./archetype": {
            "types": "./dist/archetype.d.ts",
            "import": "./dist/archetype.mjs",
            "require": "./dist/archetype.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.mjs",
            "require": "./dist/types.js"
        }
    },
    "scripts": {
        "build": "rollup -c rollup.config.mjs",
        "clean": "rimraf dist",
        "test": "vitest run"
    },
    "dependencies": {
        "@axrone/ecs-events": "^0.1.0",
        "@axrone/ecs-query": "^0.1.0",
        "@axrone/ecs-storage": "^0.1.0",
        "@axrone/numeric": "^0.0.1",
        "@axrone/utility": "^0.0.1"
    }
}
