{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": false,
        "types": ["node"],
        "declaration": true,
        "declarationMap": false,
        "sourceMap": true
    },
    "include": ["src/**/*.ts", "types.ts", "../../types/**/*.d.ts"],
    "exclude": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/*.browser.test.ts",
        "**/*.browser.spec.ts",
        "dist"
    ]
}
