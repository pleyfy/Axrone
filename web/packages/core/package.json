{
    "name": "@axrone/core",
    "version": "0.1.0",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "rollup -c rollup.config.mjs",
        "clean": "rimraf dist",
        "test": "vitest run --passWithNoTests --root ../.. packages/core/src/**/*.test.ts packages/core/src/**/*.spec.ts packages/core/src/__tests__/**/*.test.ts packages/core/src/__tests__/**/*.spec.ts"
    }
}
