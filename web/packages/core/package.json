{
    "name": "@axrone/core",
    "version": "0.1.0",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./scene-runtime": {
            "types": "./dist/scene-runtime/index.d.ts",
            "import": "./dist/scene-runtime/index.mjs",
            "require": "./dist/scene-runtime/index.js"
        },
        "./scene-3d": {
            "types": "./dist/scene-3d/index.d.ts",
            "import": "./dist/scene-3d/index.mjs",
            "require": "./dist/scene-3d/index.js"
        },
        "./runtime-profile-core": {
            "types": "./dist/runtime-profile-core/index.d.ts",
            "import": "./dist/runtime-profile-core/index.mjs",
            "require": "./dist/runtime-profile-core/index.js"
        },
        "./runtime-profile-3d": {
            "types": "./dist/runtime-profile-3d/index.d.ts",
            "import": "./dist/runtime-profile-3d/index.mjs",
            "require": "./dist/runtime-profile-3d/index.js"
        },
        "./runtime-profile-full": {
            "types": "./dist/runtime-profile-full/index.d.ts",
            "import": "./dist/runtime-profile-full/index.mjs",
            "require": "./dist/runtime-profile-full/index.js"
        }
    },
    "scripts": {
        "build": "rollup -c rollup.config.mjs",
        "clean": "rimraf dist",
        "test": "vitest run"
    },
    "dependencies": {
        "@axrone/numeric": "^0.0.1",
        "@axrone/random": "^0.0.1",
        "@axrone/utility": "^0.0.1",
        "@loaders.gl/core": "^4.4.1",
        "@loaders.gl/textures": "^4.4.1",
        "draco3dgltf": "^1.5.7",
        "meshoptimizer": "^1.0.1"
    }
}
