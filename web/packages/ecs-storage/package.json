{
    "name": "@axrone/ecs-storage",
    "version": "0.1.0",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./component-pool": {
            "types": "./dist/component-pool.d.ts",
            "import": "./dist/component-pool.mjs",
            "require": "./dist/component-pool.js"
        },
        "./archetype": {
            "types": "./dist/archetype.d.ts",
            "import": "./dist/archetype.mjs",
            "require": "./dist/archetype.js"
        },
        "./entity-store": {
            "types": "./dist/entity-store.d.ts",
            "import": "./dist/entity-store.mjs",
            "require": "./dist/entity-store.js"
        },
        "./archetype-store": {
            "types": "./dist/archetype-store.d.ts",
            "import": "./dist/archetype-store.mjs",
            "require": "./dist/archetype-store.js"
        },
        "./world-storage-runtime": {
            "types": "./dist/world-storage-runtime.d.ts",
            "import": "./dist/world-storage-runtime.mjs",
            "require": "./dist/world-storage-runtime.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.mjs",
            "require": "./dist/types.js"
        }
    },
    "scripts": {
        "build": "rollup -c rollup.config.mjs",
        "clean": "rimraf dist",
        "test": "vitest run"
    },
    "dependencies": {
        "@axrone/memory": "^0.0.1"
    }
}
