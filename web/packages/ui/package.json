{
    "name": "@axrone/ui",
    "version": "0.0.1",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./runtime": {
            "types": "./dist/runtime/index.d.ts",
            "import": "./dist/runtime/index.mjs",
            "require": "./dist/runtime/index.js"
        },
        "./layout": {
            "types": "./dist/layout/index.d.ts",
            "import": "./dist/layout/index.mjs",
            "require": "./dist/layout/index.js"
        },
        "./render": {
            "types": "./dist/render/index.d.ts",
            "import": "./dist/render/index.mjs",
            "require": "./dist/render/index.js"
        },
        "./text": {
            "types": "./dist/text/index.d.ts",
            "import": "./dist/text/index.mjs",
            "require": "./dist/text/index.js"
        },
        "./font": {
            "types": "./dist/font/index.d.ts",
            "import": "./dist/font/index.mjs",
            "require": "./dist/font/index.js"
        },
        "./widget": {
            "types": "./dist/widget/index.d.ts",
            "import": "./dist/widget/index.mjs",
            "require": "./dist/widget/index.js"
        },
        "./controls": {
            "types": "./dist/controls/index.d.ts",
            "import": "./dist/controls/index.mjs",
            "require": "./dist/controls/index.js"
        }
    },
    "scripts": {
        "build": "rollup -c rollup.config.mjs",
        "clean": "rimraf dist",
        "test": "vitest run --config vitest.config.ts"
    },
    "dependencies": {
        "@axrone/utility": "^0.0.1"
    }
}
